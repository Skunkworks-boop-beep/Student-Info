# Frontend (Vite). When both are set, the app uses Supabase Auth + live data.
# Run all SQL files in supabase/migrations/ in order in the Supabase SQL Editor.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Shown on Support page as mailto target (student-facing helpdesk).
# VITE_SUPPORT_EMAIL=support@yourcampus.edu

# Leave Supabase vars unset for local-only demo mode (browser accounts + static catalog).

# --- Edge Functions (Supabase secrets — never commit real keys) ---
# supabase secrets set RESEND_API_KEY=re_xxxx
# supabase secrets set SEND_EMAIL_HOOK_SECRET="v1,whsec_...."   # from Dashboard → Auth → Hooks
# supabase secrets set RESEND_FROM="Your App <notifications@yourdomain.com>"   # verified domain in Resend
# Optional: supabase secrets set APP_NAME="Student.Info"
